<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SecureTech Employee Login</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

<div class="login-box" id="loginBox">

    <h1>SecureTech Solutions Pvt. Ltd.</h1>

    <h3>Employee Login Portal</h3>

    <input type="email" placeholder="Email Address">

    <input type="password" placeholder="Password">

    <button onclick="showAwareness()">
        Sign In
    </button>

</div>

<div class="message-box" id="messageBox">

    <h2>🛡️ Phishing Awareness Simulation</h2>

    <p>
        This was a cybersecurity awareness demonstration.
    </p>

    <p>
        Always verify:
    </p>

    <ul>
        <li>✔ Sender Email Address</li>
        <li>✔ Website URL</li>
        <li>✔ HTTPS Connection</li>
        <li>✔ Unexpected Login Requests</li>
    </ul>

    <p>

        Never enter your credentials unless you have verified the authenticity of the website.

    </p>

    <h3>Thank you for participating!</h3>

</div>

<script src="script.js"></script>
    
</body>
</html>
